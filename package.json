{
  "name": "pullora",
  "version": "5.10.0",
  "description": "GitHub program launcher - download and run applications from GitHub releases",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:i18n && npm run check:contrast && tsc && vite build",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:contrast": "node scripts/check-theme-contrast.mjs",
    "test:components": "node scripts/check-library-components.mjs",
    "check:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-release.ps1",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri-dev": "tauri dev",
    "tauri-build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.3.3",
    "vite": "^7.3.6"
  }
}
